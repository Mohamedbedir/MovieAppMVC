<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MovieApp</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>

        body {
            background-color: #f5f6fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */
        .navbar {
            background: linear-gradient(135deg, #1f1f2e, #2b2b3c);
        }

            .navbar .nav-link {
                color: #ddd !important;
                transition: 0.3s;
            }

                .navbar .nav-link:hover {
                    color: #fff !important;
                }

        .navbar-brand {
            font-size: 20px;
            letter-spacing: 1px;
        }

        /* FOOTER */
        .footer {
            background: #11984596;
            color: white;
        }

        .footer-link {
            color: #bbb;
            text-decoration: none;
            transition: .3s;
        }

            .footer-link:hover {
                color: white;
            }

        .footer-P {
            color: #bbb;
            text-decoration: none;
        }

        /* TOAST */
        .custom-toast {
            min-width: 320px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            margin-bottom: 10px;
        }

        /* MOBILE */
        @@media (max-width: 768px) {

            .floating-btn {
                bottom: 70px !important;
                right: 15px !important;
                padding: 8px 14px !important;
            }

            .navbar-brand {
                font-size: 18px;
            }
        }

    </style>

</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">

        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand fw-bold"
               asp-controller="Movie"
               asp-action="Index">

                🎬 MovieApp
            </a>

            <!-- TOGGLE -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navBar">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navBar">

                <!-- CENTER -->
                <ul class="navbar-nav mx-auto text-center fw-semibold">

                    <!-- Movies (Admin + User) -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Movie"
                           asp-action="Index">
                            🎥 Movies
                        </a>
                    </li>

                    <!-- Actors (Admin + User) -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Actor"
                           asp-action="Index">
                            🎭 Actors
                        </a>
                    </li>

                    <!-- Producers (Admin + User) -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Producer"
                           asp-action="Index">
                            👤 Producers
                        </a>
                    </li>

                    <!-- Cinemas (Admin + User) -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Cinema"
                           asp-action="Index">
                            🎬 Cinemas
                        </a>
                    </li>

                    <!-- Users (Admin only) -->
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="User"
                               asp-action="Index">
                                👤 Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Roles"
                               asp-action="Index">
                                🛡 Roles
                            </a>
                        </li>
                    }

                </ul>

                <!-- RIGHT -->
                <ul class="navbar-nav ms-auto text-center">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light fw-bold"
                               asp-controller="User"
                               asp-action="Details"
                               asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">

                                👋 Hi @User.Identity.Name
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">

                                <button type="submit"
                                        class="btn btn-danger px-3">

                                    Sign Out
                                </button>

                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item mb-2 mb-lg-0">

                            <a class="nav-link btn btn-outline-light me-2 px-3"
                               asp-controller="Account"
                               asp-action="Login">

                                Login
                            </a>
                        </li>

                        <li class="nav-item">

                            <a class="btn btn-success px-3"
                               asp-controller="Account"
                               asp-action="Register">

                                Sign Up
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <!-- ================= TOAST ================= -->
    <div class="toast-container position-fixed top-0 end-0 p-4"
         style="z-index: 9999;">

        @if (TempData["SuccessAdd"] != null)
        {
            <div class="toast custom-toast bg-success text-white border-0">

                <div class="d-flex align-items-center">

                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessAdd"]
                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2"
                            data-bs-dismiss="toast">
                    </button>

                </div>

            </div>
        }

        @if (TempData["SuccessUpdate"] != null)
        {
            <div class="toast custom-toast bg-warning text-dark border-0">

                <div class="d-flex align-items-center">

                    <div class="toast-body">
                        <i class="bi bi-pencil-fill me-2"></i>
                        @TempData["SuccessUpdate"]
                    </div>

                    <button type="button"
                            class="btn-close me-2"
                            data-bs-dismiss="toast">
                    </button>

                </div>

            </div>
        }

        @if (TempData["SuccessDelete"] != null)
        {
            <div class="toast custom-toast bg-danger text-white border-0">

                <div class="d-flex align-items-center">

                    <div class="toast-body">
                        <i class="bi bi-trash-fill me-2"></i>
                        @TempData["SuccessDelete"]
                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2"
                            data-bs-dismiss="toast">
                    </button>

                </div>

            </div>
        }

    </div>

    <!-- ================= BODY ================= -->
    <main class="container my-4 flex-grow-1">
        @RenderBody()
    </main>

    <!-- ================= FOOTER ================= -->
    <footer class="footer mt-auto py-4">

        <div class="container">

            <div class="row text-center text-md-start">

                <!-- ABOUT -->
                <div class="col-md-4 mb-3">

                    <h5 class="fw-bold">🎬 MovieApp</h5>

                    <p class="text-muted small" id="aboutText">
                        منصة لعرض الأفلام والمنتجين بشكل احترافي وسهل الاستخدام.
                    </p>

                </div>

                <!-- LINKS -->
                <div class="col-md-4 mb-3">

                    <h6 class="fw-bold" id="linksTitle">
                        Quick Links
                    </h6>

                    <ul class="list-unstyled">

                        <li>
                            <a asp-controller="Movie"
                               asp-action="Index"
                               class="footer-link"
                               id="moviesLink">

                                Movies
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Producer"
                               asp-action="Index"
                               class="footer-link"
                               id="producersLink">

                                Producers
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Cinema"
                               asp-action="Index"
                               class="footer-link"
                               id="CinemasLink">

                                Cinemas
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Actor"
                               asp-action="Index"
                               class="footer-link"
                               id="ActorsLink">

                                Actors
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- CONTACT -->
                <div class="col-md-4 mb-3">

                    <h6 class="fw-bold" id="contactTitle">
                        Contact
                    </h6>

                    <p class="small text-muted mb-1">
                        📧 ozomBedir@gmail.com
                    </p>

                    <p class="small text-muted">
                        📞 +20 1044714369
                    </p>

                    <!-- LANGUAGE SWITCH -->
                    <button class="btn btn-outline-light btn-sm mt-2"
                            onclick="toggleLang()">

                        🌐 عربي / English
                    </button>

                </div>

            </div>

            <hr />

            <div class="text-center small text-muted"
                 id="copyText">

                © 2026 MovieApp - All Rights Reserved
            </div>

        </div>

    </footer>

    <!-- ================= SCRIPTS ================= -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        // TOAST
        window.addEventListener('DOMContentLoaded', () => {

            const toastElList = document.querySelectorAll('.toast');

            toastElList.forEach(toastEl => {

                const toast = new bootstrap.Toast(toastEl, {
                    delay: 5000
                });

                toast.show();
            });

        });

        // LANGUAGE
        let isArabic = false;

        function toggleLang() {

            isArabic = !isArabic;

            if (isArabic) {

                document.documentElement.dir = "rtl";
                document.documentElement.lang = "ar";

                document.getElementById("aboutText").innerText =
                    "منصة لعرض الأفلام والمنتجين بشكل احترافي وسهل الاستخدام";

                document.getElementById("linksTitle").innerText = "روابط سريعة";
                document.getElementById("moviesLink").innerText = "الأفلام";
                document.getElementById("producersLink").innerText = "المنتجين";
                document.getElementById("CinemasLink").innerText = "السينمات";
                document.getElementById("ActorsLink").innerText = "الممثلين";
                document.getElementById("contactTitle").innerText = "تواصل معنا";

                document.getElementById("copyText").innerText =
                    "© 2026 جميع الحقوق محفوظة";

            }
            else {

                document.documentElement.dir = "ltr";
                document.documentElement.lang = "en";

                document.getElementById("aboutText").innerText =
                    "A platform to showcase movies and producers in a modern way.";

                document.getElementById("linksTitle").innerText = "Quick Links";
                document.getElementById("moviesLink").innerText = "Movies";
                document.getElementById("producersLink").innerText = "Producers";
                document.getElementById("CinemasLink").innerText = "Cinemas";
                document.getElementById("ActorsLink").innerText = "Actors";
                document.getElementById("contactTitle").innerText = "Contact";

                document.getElementById("copyText").innerText =
                    "© 2026 MovieApp - All Rights Reserved";
            }
        }

    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>