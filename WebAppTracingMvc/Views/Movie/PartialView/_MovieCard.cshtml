@model IEnumerable<MovieViewModel>

@if (Model != null && Model.Any())
{
    @foreach (var movie in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100 position-relative">

                <!-- DETAILS ICON TOP RIGHT -->
                <div class="position-absolute top-0 end-0 m-2">

                    <a asp-action="Details"
                       asp-route-id="@movie.Id"
                       class="btn btn-light rounded-circle shadow-sm icon-btn">

                        <i class="fa-solid fa-circle-info text-primary"></i>

                    </a>

                </div>

                <!-- IMAGE -->
                @if (!string.IsNullOrEmpty(movie.ImageURL))
                {
                    <img src="@Url.Content($"~/Files/Images/{movie.ImageURL}")"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />
                }
                else
                {
                    <div class="text-center p-5">
                        <i class="bi bi-film fs-1"></i>
                    </div>
                }

                <div class="card-body d-flex flex-column">

                    <h5>@movie.Name</h5>

                    <p class="text-muted small">
                        @movie.Description
                    </p>

                    <!-- ACTIONS -->
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mt-auto d-flex justify-content-center custom-gap">

                            <a asp-action="Edit"
                               asp-route-id="@movie.Id"
                               class="btn btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@movie.Id"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button class="btn btn-outline-danger"
                                        onclick="return confirm('Are you sure?');">

                                    <i class="bi bi-trash"></i>

                                </button>

                            </form>

                        </div>
                    }

                </div>

            </div>

        </div>
    }
}
else
{
    <div class="col-12 text-center mt-5">
        <h5 class="text-muted">No Movies Found 🎬</h5>
    </div>
}