@model MovieViewModel

<!-- ========================= -->
<!-- CREATE MODAL -->
<!-- ========================= -->

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">Add New Movie</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <form asp-action="Create" method="post" id="createForm" enctype="multipart/form-data">

                    <input name="Name"
                           class="form-control mb-2 required"
                           placeholder="Name" />

                    <input name="Description"
                           class="form-control mb-2 required"
                           placeholder="Description" />

                   <input name="Price"
                           type="number"
                           class="form-control mb-2 required"
                           placeholder="Price" />

                    <input name="StartDate"
                           type="date"
                           class="form-control mb-2 required" />

                    <input name="EndDate"
                           type="date"
                           class="form-control mb-2 required" />

                    <input name="Catigory"
                           class="form-control mb-2 required"
                           placeholder="Category" />

                    <!-- PRODUCER -->
                    <div class="mb-3">
                        <label class="form-label">Producer</label>

                        <select asp-for="ProducerId"
                                class="form-control"
                                asp-items="ViewBag.Producers">

                            <option value="">-- Select Producer --</option>

                        </select>
                    </div>
                    <!-- CINEMA -->
                    <div class="mb-3">
                        <label class="form-label">Cinema</label>

                        <select asp-for="CinemaId"
                                class="form-control"
                                asp-items="ViewBag.Cinemas">

                            <option value="">-- Select Cinema --</option>

                        </select>
                    </div>
                    <!-- ACTORS CHECKLIST -->
                    <div class="mb-3">
                        <label class="form-label">Actors</label>

                        <div style="max-height:200px; overflow:auto; border:1px solid #ddd; padding:10px; border-radius:8px;">

                            @foreach (var actor in ((MovieViewModel)ViewBag.MovieVM).AllActors)
                            {
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="SelectedActorsIds"
                                           value="@actor.Id"
                                           id="actor_@actor.Id" />

                                    <label class="form-check-label" for="actor_@actor.Id">
                                        @actor.FullName
                                    </label>
                                </div>
                            }

                        </div>
                    </div>
                    <!--Image-->
                    <input type="file"
                           name="Image"
                           id="imgInput"
                           class="form-control mb-2"
                           accept="image/*" />

                    <!-- PREVIEW -->
                    <div class="text-center mb-3">

                        <img id="preview"
                             class="d-none"
                             style="width:120px;height:120px;border-radius:50%;object-fit:cover;" />

                        <p id="placeholder" class="text-muted">Image Preview</p>

                    </div>

                    <!-- SAVE -->
                    <button id="saveBtn"
                            class="btn btn-success w-100"
                            disabled>
                        💾 Save
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>


<script src="bootstrap.bundle.min.js"></script>
<script>

    const form = document.getElementById("createForm");
    const saveBtn = document.getElementById("saveBtn");

    // enable save button
    form.addEventListener("input", () => {

        let valid = true;

        document.querySelectorAll(".required").forEach(x => {
            if (!x.value.trim()) valid = false;
        });

        saveBtn.disabled = !valid;
    });


        const input = document.getElementById("imgInput");
    const preview = document.getElementById("preview");
    const placeholder = document.getElementById("placeholder");

    input.addEventListener("change", () => {

        const file = input.files[0];

        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.classList.remove("d-none");
            placeholder.style.display = "none";
        } else {
            preview.classList.add("d-none");
            placeholder.style.display = "block";
        }

    });

</script>