@model IEnumerable<MovieViewModel>

<style>
    .movie-img {
        transition: transform 0.4s ease, filter 0.4s ease;
    }

        .movie-img:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

    .custom-gap {
        gap: 30px;
    }

    .floating-btn {
        position: fixed;
        bottom: 90px;
        right: 25px;
        z-index: 9999;
        border-radius: 50px;
        padding: 10px 18px;
    }

    .search-box {
        max-width: 350px;
    }
</style>

<div class="container mt-4">

    <!-- HEADER + SEARCH -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="fw-bold">🎬 Movies</h3>

        <div class="input-group search-box shadow-sm">

            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>

            <input type="text"
                   id="searchInput"
                   class="form-control border-start-0"
                   placeholder="Search movie..." />

        </div>

    </div>

    <!-- RESULTS -->
    <div id="moviesContainer" class="row">

        @Html.Partial("PartialView/_MovieCard", Model)

    </div>

</div>

 @if (User.IsInRole("Admin"))
{
<!-- CREATE -->
    <button class="btn btn-success shadow-lg floating-btn d-flex align-items-center gap-2"
            data-bs-toggle="modal"
            data-bs-target="#createModal">

        <i class="bi bi-plus fs-5"></i>
        <span>Add Movie</span>

    </button>
 }
<partial name="PartialView/_CreatePartialView" model="new MovieViewModel()" />

<!-- ================= JS ================= -->
<script>

    document.addEventListener("DOMContentLoaded", function () {

        const input = document.getElementById("searchInput");
        const container = document.getElementById("moviesContainer");

        let timer;

        input.addEventListener("keyup", function () {

            clearTimeout(timer);

            timer = setTimeout(() => {

                fetch(`/Movie/Search?term=${encodeURIComponent(input.value)}`)
                    .then(res => res.text())
                    .then(html => {
                        container.innerHTML = html;
                    });

            }, 300);

        });

    });

</script>