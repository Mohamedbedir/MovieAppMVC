@model MovieViewModel

<style>
    .movie-img {
        transition: transform 0.4s ease, filter 0.4s ease;
    }

        .movie-img:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

    .custom-gap {
        gap: 15px;
    }

    /* scroll للمحتوى */
    .details-container {
        max-height: 75vh;
        overflow-y: auto;
    }

    /* الأكشنز */
    .sticky-actions {
        margin-top: auto;
        background: #fff;
        padding: 15px;
        border-top: 1px solid #eee;
        width: 100%;
    }
  
  @@media (max-width: 768px) {
        .details-container

    {
        max-height: none;
        overflow: visible;
    }

    }
   
    /* responsive */
    
</style>

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="row g-0">

            <!-- IMAGE -->
            <div class="col-md-5">

                <img src="@(
                     !string.IsNullOrEmpty(Model.ImageURL)
                     ? Url.Content($"~/Files/Images/{Model.ImageURL}")
                     : Url.Content("~/images/default-producer.png")
                                )"
                     class="w-100 h-100 movie-img"
                     style="object-fit: cover; min-height: 100%;"
                     onerror="this.src='@Url.Content("~/images/default-producer.png")'" />

            </div>

            <!-- DETAILS -->
            <div class="col-md-7 d-flex flex-column">

                <div class="card-body p-4 flex-grow-1 details-container">

                    <!-- TITLE -->
                    <h2 class="fw-bold mb-2">@Model.Name</h2>

                    <!-- STATUS -->
                    <div class="mb-3">
                        @if (Model.StartDate > DateTime.Now)
                        {
                            <span class="badge bg-warning">Coming Soon</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Available</span>
                        }
                    </div>

                    <!-- DESCRIPTION -->
                    <p class="text-muted mb-4">
                        @Model.Description
                    </p>

                    <!-- INFO -->
                    <div class="row g-3 mb-4">

                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Category</small>
                                <div class="fw-semibold">@Model.Catigory</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Start Date</small>
                                <div class="fw-semibold">@Model.StartDate.ToShortDateString()</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Price</small>
                                <div class="fw-semibold text-success">
                                    @Model.Price.ToString("C", new System.Globalization.CultureInfo("ar-EG"))
                                </div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">End Date</small>
                                <div class="fw-semibold">@Model.EndDate.ToShortDateString()</div>
                            </div>
                        </div>

                        <!-- Producer -->
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted d-block mb-2">Producer</small>

                                @if (Model.Producer != null)
                                {
                                    <a asp-controller="Producer"
                                       asp-action="Details"
                                       asp-route-id="@Model.Producer.Id"
                                       class="badge bg-light text-dark px-3 py-2 text-decoration-none"
                                       style="border-radius:20px; border:1px solid #ddd;">
                                        @Model.Producer.FullName
                                    </a>
                                }
                                else
                                {
                                    <span class="text-danger fw-semibold">No Producer</span>
                                }
                            </div>
                        </div>

                        <!-- Cinema -->
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted d-block mb-2">Cinema</small>

                                @if (Model.Cinema != null)
                                {
                                    <a asp-controller="Cinema"
                                       asp-action="Details"
                                       asp-route-id="@Model.Cinema.Id"
                                       class="badge bg-light text-dark px-3 py-2 text-decoration-none"
                                       style="border-radius:20px; border:1px solid #ddd;">
                                        @Model.Cinema.Name
                                    </a>
                                }
                                else
                                {
                                    <span class="text-danger fw-semibold">No Cinema</span>
                                }
                            </div>
                        </div>

                        <!-- Actors -->
                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">

                                <small class="text-muted d-block mb-2">Actors</small>

                                @if (Model.Actors != null && Model.Actors.Any())
                                {
                                    <div class="d-flex flex-wrap align-items-center">

                                        @for (int i = 0; i < Model.Actors.Count; i++)
                                        {
                                            <a asp-controller="Actor"
                                               asp-action="Details"
                                               asp-route-id="@Model.Actors[i].Id"
                                               class="badge bg-light text-dark px-3 py-2 text-decoration-none me-1"
                                               style="border-radius:20px; border:1px solid #ddd;">
                                                @Model.Actors[i].FullName
                                            </a>

                                            @if (i < Model.Actors.Count - 1)
                                            {
                                                <span class="mx-1 text-muted">•</span>
                                            }
                                        }

                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No actors available</p>
                                }

                            </div>
                        </div>

                    </div>

                </div>

                <!-- ACTIONS (FIXED FULL WIDTH) -->
                <div class="sticky-actions d-flex justify-content-between align-items-center custom-gap">

                    <button onclick="history.back()"
                            class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                    </button>
                     @if (User.IsInRole("Admin"))
                    {
                        <div class="d-flex gap-2">

                            <a asp-action="Edit" asp-route-id="@Model.Id"
                            class="btn btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                                <button type="submit"
                                class="btn btn-danger"
                                onclick="return confirm('Are you sure you want to delete this movie?');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>

                        </div>
                    }
                </div>

            </div>

        </div>

    </div>

</div>