@model ActorViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .preview-box {
        height: 180px;
        border: 2px dashed #ddd;
        border-radius: 12px;
        background: #f8f9fa;
    }

    .avatar-preview {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
    }

    .icon {
        font-size: 40px;
        color: gray;
    }
</style>

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow p-4">

                <h3 class="text-center mb-4">✏️ Edit Actor</h3>

                <form asp-action="Edit"
                      method="post"
                      enctype="multipart/form-data"
                      id="editForm">

                    <input type="hidden" asp-for="Id" />

                    <!-- NAME -->
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName"
                               class="form-control required-field" />
                    </div>

                    <!-- BIO -->
                    <div class="mb-3">
                        <label asp-for="Bio" class="form-label"></label>
                        <textarea asp-for="Bio"
                                  class="form-control required-field"></textarea>
                    </div>

                    <!-- SALARY -->
                    <div class="mb-3">
                        <label asp-for="Salary" class="form-label"></label>
                        <input asp-for="Salary"
                               class="form-control required-field" />
                    </div>

                    <!-- IMAGE -->
                    <div class="mb-3">
                        <label class="form-label">Actor Image</label>
                        <input type="file"
                               name="Image"
                               id="imageInput"
                               class="form-control"
                               accept="image/*" />
                    </div>

                    <!-- PREVIEW -->
                    <div class="mb-4 text-center">

                        <div class="preview-box d-flex flex-column justify-content-center align-items-center">

                            <i class="bi bi-image icon" id="placeholderIcon"></i>

                            <img id="previewImage"
                                 class="avatar-preview d-none" />

                        </div>

                    </div>

                    <!-- BUTTONS -->
                    <div class="d-flex justify-content-between">

                        <button type="button"
                                onclick="history.back()"
                                class="btn btn-secondary px-4">
                            ⬅ Back
                        </button>

                        <button type="submit"
                                id="saveBtn"
                                class="btn btn-success px-4"
                                disabled>
                            💾 Save
                        </button>

                    </div>

                </form>

            </div>

        </div>
    </div>

</div>

@section Scripts {

    <script>
        const form = document.getElementById("editForm");
        const saveBtn = document.getElementById("saveBtn");

        const imageInput = document.getElementById("imageInput");
        const previewImage = document.getElementById("previewImage");
        const placeholder = document.getElementById("placeholderIcon");

        // =========================
        // Enable button
        // =========================
        form.addEventListener("input", function () {

            let valid = true;

            document.querySelectorAll(".required-field").forEach(f => {
                if (!f.value.trim()) valid = false;
            });

            saveBtn.disabled = !valid;
        });

        // =========================
        // Load OLD image on load
        // =========================
        window.addEventListener("load", function () {

            let oldImage = "@(Model.ProfilePictureUrl != null ? Url.Content($"~/Files/Images/{Model.ProfilePictureUrl}") : "")";

            if (oldImage !== "") {
                previewImage.src = oldImage;
                previewImage.classList.remove("d-none");
                placeholder.style.display = "none";
            }
        });

        // =========================
        // Preview new image
        // =========================
        imageInput.addEventListener("change", function () {

            const file = this.files[0];

            if (file) {
                const url = URL.createObjectURL(file);

                previewImage.src = url;
                previewImage.classList.remove("d-none");
                placeholder.style.display = "none";
            }
        });
    </script>

}