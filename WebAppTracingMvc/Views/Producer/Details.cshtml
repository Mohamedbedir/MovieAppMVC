@model ProducerViewModel

@* <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
 *@
<style>
    .details-card {
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(135deg, #ffffff, #f8f9fa);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    /* 👇 Bigger avatar */
    .avatar {
        width: 220px;
        height: 220px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid #fff;
        box-shadow: 0 15px 30px rgba(0,0,0,0.15);
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 15px;
    }

    /* 👇 Icon buttons */
    .icon-btn {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }

        .icon-btn:hover {
            transform: scale(1.1);
        }

    /* spacing between icons */
    .icon-gap {
        gap: 18px;
    }
</style>

<div class="container mt-5">

    <div class="card details-card p-4">

        <div class="row align-items-center">

            <!-- IMAGE -->
            <div class="col-md-4 text-center">

                <img src="@(
                     !string.IsNullOrEmpty(Model.ProfilePictureURL)
                     ? Url.Content($"~/Files/Images/{Model.ProfilePictureURL}")
                     : Url.Content("~/images/default-producer.png")
                                )"
                     class="avatar"
                     onerror="this.src='@Url.Content("~/images/default-producer.png")'" />

            </div>

            <!-- INFO -->
            <div class="col-md-8">

                <h2 class="fw-bold">@Model.FullName</h2>

                <div class="info-box mt-3">
                    <h6 class="text-muted">Bio</h6>
                    <p class="mb-0">
                        @Model.Bio
                    </p>
                </div>
                <!-- MOVIES -->
                <div class="info-box mt-3">
                    <h6 class="text-muted mb-2">Movies</h6>

                    @if (Model.Movies != null && Model.Movies.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">

                            @for (int i = 0; i < Model.Movies.Count; i++)
                            {
                                <a asp-controller="Movie"
                                   asp-action="Details"
                                   asp-route-id="@Model.Movies[i].Id"
                                   class="badge bg-light text-dark px-3 py-2 text-decoration-none"
                                   style="border-radius:20px; border:1px solid #ddd;">

                                    @Model.Movies[i].Name

                                </a>
                            }

                        </div>
                    }
                    else
                    {
                        <p class="mb-0 text-muted">No movies available</p>
                    }
                </div>

                <!-- ACTION ICONS -->
                <div class="mt-4 d-flex icon-gap">

                    <button onclick="history.back()"
                             class="btn btn-outline-secondary icon-btn"
                             title="Back">
                             <i class="bi bi-arrow-left"></i>
                    </button>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                        class="btn btn-outline-warning icon-btn"
                        title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                            <button type="submit"
                            class="btn btn-outline-danger icon-btn"
                            title="Delete"
                            onclick="return confirm('Are you sure?');">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    }

                </div>

            </div>

        </div>

    </div>

</div>