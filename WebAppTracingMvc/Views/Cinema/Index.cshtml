@model IEnumerable<CinemaViewModel>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>

    .custom-card {
        background: linear-gradient(135deg, #ffffff, #f8f9fa);
        border-radius: 16px;
        transition: 0.4s;
    }

        .custom-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.08);
        }

    .icon-btn {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .custom-gap {
        gap: 14px;
    }

    .avatar-box {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
    }

        .avatar-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .floating-btn {
        position: fixed;
        bottom: 90px;
        right: 25px;
        z-index: 9999;
        border-radius: 50px;
        padding: 10px 18px;
    }

    .search-box {
        max-width: 350px;
    }

</style>

<div class="container mt-4">

    <!-- HEADER + SEARCH -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">

        <h3 class="fw-bold m-0">🎬 Cinemas</h3>

        <div class="input-group shadow-sm search-box">

            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>

            <input type="text"
                   id="searchInput"
                   class="form-control border-start-0"
                   placeholder="Search cinema..." />

        </div>

    </div>

    <!-- CARDS -->
    <div id="cinemasContainer" class="row">

        @Html.Partial("PartialView/_CinemaCards", Model)

    </div>

</div>

<!-- FLOAT BUTTON -->
@if (User.IsInRole("Admin"))
{
    <button class="btn btn-success shadow-lg floating-btn d-flex align-items-center gap-2"
            data-bs-toggle="modal"
            data-bs-target="#createCinemaModal">

        <i class="bi bi-plus fs-5"></i>
        <span>Add Cinema</span>

    </button>
}


<!-- CREATE MODAL -->
<partial name="PartialView/_CreateCinemaPartialView" />

<!-- ================= JS ================= -->
<script>
    const input = document.getElementById("searchInput");
    const container = document.getElementById("cinemasContainer");

    let timer;

    input.addEventListener("keyup", function () {

        clearTimeout(timer);

        timer = setTimeout(() => {

            fetch(`/Cinema/Search?term=${encodeURIComponent(input.value)}`)
                .then(res => res.text())
                .then(html => {

                    console.log("RESPONSE HTML:", html);

                    container.innerHTML = html;

                })
                .catch(err => console.log("ERROR:", err));

        }, 300);

    });
</script>