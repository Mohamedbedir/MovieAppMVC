<!-- ===================== -->
<!-- CREATE MODAL -->
<!-- ===================== -->

<div class="modal fade" id="createCinemaModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title"> Add New Cinema</h5>
                <button type="button" class="bi bi-x-lg btn-outline-danger" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <form asp-action="Create" method="post" id="cinemaForm" enctype="multipart/form-data">

                    <!-- NAME -->
                    <input name="Name"
                           class="form-control mb-2 required-field"
                           placeholder="Name Of Cinema" />

                    <!-- BIO -->
                    <textarea name="Description"
                              class="form-control mb-2 required-field"
                              placeholder="Description"></textarea>

                    <!-- ADDRESS -->
                    <input name="Address"
                           class="form-control mb-2 required-field"
                           placeholder="Address" />

                    <!-- IMAGE -->
                    <input type="file"
                           name="Image"
                           id="imgInput"
                           class="form-control mb-2"
                           accept="image/*" />

                    <!-- PREVIEW -->
                    <div class="text-center mb-3">

                        <img id="preview"
                             class="d-none"
                             style="width:120px;height:120px;border-radius:50%;object-fit:cover;" />

                        <p id="placeholder" class="text-muted">Image Preview</p>

                    </div>

                    <!-- SAVE -->
                    <button id="saveBtn" class="btn btn-success w-100" disabled>
                        💾 Save
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>

<!-- ===================== -->
<!-- SCRIPT -->
<!-- ===================== -->

<script>

    const form = document.getElementById("cinemaForm");
    const saveBtn = document.getElementById("saveBtn");

    // Enable button only if fields filled
    form.addEventListener("input", () => {

        let valid = true;

        document.querySelectorAll(".required-field").forEach(f => {
            if (!f.value.trim()) valid = false;
        });

        saveBtn.disabled = !valid;
    });

        const input = document.getElementById("imgInput");
    const preview = document.getElementById("preview");
    const placeholder = document.getElementById("placeholder");

    input.addEventListener("change", () => {

        const file = input.files[0];

        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.classList.remove("d-none");
            placeholder.style.display = "none";
        } else {
            preview.classList.add("d-none");
            placeholder.style.display = "block";
        }

    });
</script>